{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "reviews-proxy",
  "main": "reviews-proxy.js",
  "compatibility_date": "2026-06-16",
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "REVIEWS_KV",
